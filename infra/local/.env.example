# LLM API Keys
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_BASE_URL=https://api.anthropic.com # Change if using a proxy

# Platform Configuration
NEXT_PUBLIC_TENANT_ID=default-tenant

# Service URLs (Local Docker Networking)
# These are typically handled by docker-compose internally, 
# but can be overridden here for host-based development.
# LLM_GATEWAY_URL=http://localhost:8083/v1
